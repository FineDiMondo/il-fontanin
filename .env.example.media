# ============================================
# ENVIRONMENT VARIABLES - MEDIA FEATURE
# ============================================
# Copy questi valori a .env.local (development) o .env.production

# GOOGLE APIs - Frontend (Public)
# ================================
VITE_GOOGLE_PICKER_API_KEY=AIzaSy... # Da Google Cloud Console > Credentials > API Key
VITE_GOOGLE_APP_ID=123456789.apps.googleusercontent.com # OAuth 2.0 Client ID

# GOOGLE APIs - Backend (Private)
# ===============================
# Scarica JSON da Google Cloud Console > Service Account > Create Key
# Copia intero JSON content qui (senza line breaks, single line)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"el-fontanin","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"el-fontanin-media@el-fontanin.iam.gserviceaccount.com"}'

# Firestore
# =========
FIRESTORE_PROJECT_ID=el-fontanin

# Google Drive - Fontanin folder ID
# ==================================
# Cartella dove vengono uploadati i media collettivi
# Formato: https://drive.google.com/drive/folders/[ID]/
GOOGLE_DRIVE_FONTANIN_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J

# Feature Flags
# =============
VITE_ENABLE_MEDIA_FEATURE=true  # Enable Media in ESPERIMENTI ATTIVI

# Monitoring
# ==========
VITE_SENTRY_DSN=https://key@sentry.io/project-id
