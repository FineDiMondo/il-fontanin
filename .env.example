# Firebase — crea progetto su https://console.firebase.google.com
# Authentication > Sign-in method > Google > Abilita
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=il-fontanin.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=il-fontanin
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Backend Community API
VITE_API_BASE_URL=https://freedomrun-491323.ey.r.appspot.com

# Donazioni — QR SEPA/EPC (bonifico gratuito, nessuna commissione)
# Lasciare vuoto per disattivare la sezione "Sostieni la community"
VITE_DONATION_IBAN=
VITE_DONATION_BENEFICIARY=
VITE_DONATION_BIC=

# MetaMask Embedded Wallets / Web3Auth (SFA)
# Registra un account su https://developer.metamask.io/ o https://dashboard.web3auth.io/
# per ottenere il Client ID. Crea un custom JWT verifier per Firebase Auth.
VITE_WEB3AUTH_CLIENT_ID=
VITE_WEB3AUTH_VERIFIER_NAME=el-fontanin-firebase-verifier

# Saldo gettoni "f" (ASA Algorand) in WalletCard — FASE 5
# ASA ID mainnet del token "f". Lasciare vuoto per nascondere il saldo
# (mostra placeholder "saldo non disponibile" invece di un numero/errore).
VITE_FONTANIN_ASA_ID=

